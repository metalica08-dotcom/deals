<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>이지스 하남 IDC 매각 — Buyer Universe 2024</title>
<style>
  :root {
    --navy: #1B2A4A;
    --dark-navy: #0F1E35;
    --gold: #C9A84C;
    --gold-light: #F0E2B6;
    --blue: #2C5F8A;
    --blue-light: #D6E4F0;
    --green: #1A6B3C;
    --green-light: #D4EDDA;
    --amber: #856404;
    --amber-light: #FFF3CD;
    --red-light: #FDDEDE;
    --grey: #F5F6FA;
    --border: #DEE2E8;
    --text: #1a1a2e;
    --text-muted: #6c757d;
    --white: #ffffff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Apple SD Gothic Neo', 'Noto Sans KR', -apple-system, sans-serif; color: var(--text); background: #F0F2F7; font-size: 14px; line-height: 1.6; }

  /* ── HERO ── */
  .hero { background: linear-gradient(135deg, var(--dark-navy) 0%, var(--navy) 60%, #2C5F8A 100%); color: white; padding: 52px 40px 40px; }
  .hero-tag { display: inline-block; background: var(--gold); color: var(--dark-navy); font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 4px; letter-spacing: .5px; margin-bottom: 16px; }
  .hero h1 { font-size: 32px; font-weight: 700; line-height: 1.2; margin-bottom: 6px; }
  .hero h1 em { color: var(--gold); font-style: normal; }
  .hero-sub { font-size: 13px; color: rgba(255,255,255,.65); margin-bottom: 32px; max-width: 640px; }
  .stats { display: flex; gap: 0; flex-wrap: wrap; border: 1px solid rgba(255,255,255,.15); border-radius: 10px; overflow: hidden; margin-bottom: 20px; max-width: 820px; }
  .stat { flex: 1; min-width: 120px; padding: 18px 20px; border-right: 1px solid rgba(255,255,255,.12); }
  .stat:last-child { border-right: none; }
  .stat-val { font-size: 22px; font-weight: 700; color: var(--gold); line-height: 1; margin-bottom: 4px; }
  .stat-label { font-size: 11px; color: rgba(255,255,255,.55); line-height: 1.3; }
  .stat-sub { font-size: 10px; color: rgba(255,255,255,.4); margin-top: 2px; }
  .meta-row { display: flex; gap: 20px; flex-wrap: wrap; font-size: 11px; color: rgba(255,255,255,.45); }
  .meta-row span b { color: rgba(255,255,255,.7); font-weight: 600; }

  /* ── NAV ── */
  .nav-wrap { background: var(--navy); position: sticky; top: 0; z-index: 100; border-bottom: 2px solid var(--gold); }
  .nav { display: flex; gap: 0; overflow-x: auto; padding: 0 32px; scrollbar-width: none; }
  .nav::-webkit-scrollbar { display: none; }
  .nav a { display: block; padding: 14px 18px; font-size: 12px; font-weight: 600; color: rgba(255,255,255,.5); text-decoration: none; white-space: nowrap; border-bottom: 3px solid transparent; transition: all .2s; }
  .nav a:hover, .nav a.active { color: var(--gold); border-bottom-color: var(--gold); }

  /* ── LAYOUT ── */
  .container { max-width: 1080px; margin: 0 auto; padding: 36px 24px; }
  .section { margin-bottom: 52px; }
  .section-title { font-size: 20px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
  .section-sub { font-size: 13px; color: var(--text-muted); margin-bottom: 24px; border-bottom: 2px solid var(--gold); padding-bottom: 12px; }

  /* ── SUMMARY GRID ── */
  .summary-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; margin-bottom: 28px; }
  .summary-card { background: white; border: 1px solid var(--border); border-radius: 10px; padding: 16px 18px; display: flex; align-items: center; gap: 12px; }
  .sc-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .sc-dot.t1 { background: var(--navy); }
  .sc-dot.t2 { background: var(--blue); }
  .sc-dot.t3 { background: #6c8db0; }
  .sc-name { font-size: 13px; font-weight: 600; color: var(--text); }
  .sc-type { font-size: 11px; color: var(--text-muted); }
  .sc-stars { margin-left: auto; font-size: 12px; color: var(--gold); }

  /* ── BUYER CARDS ── */
  .buyer-section { margin-bottom: 32px; }
  .tier-label { display: inline-flex; align-items: center; gap: 8px; background: var(--navy); color: white; font-size: 11px; font-weight: 700; padding: 5px 14px; border-radius: 20px; margin-bottom: 16px; }
  .tier-label.t2 { background: var(--blue); }
  .tier-label.t3 { background: #4A7BA7; }
  .buyer-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 16px; }
  .buyer-card { background: white; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: box-shadow .2s; }
  .buyer-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,.08); }
  .buyer-card.winner { border-color: var(--green); background: var(--green-light); }
  .card-head { padding: 16px 18px 12px; border-bottom: 1px solid var(--border); display: flex; align-items: flex-start; gap: 12px; }
  .buyer-card.winner .card-head { border-bottom-color: rgba(26,107,60,.2); }
  .card-num { width: 28px; height: 28px; background: var(--navy); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; flex-shrink: 0; }
  .buyer-card.winner .card-num { background: var(--green); }
  .card-title-wrap { flex: 1; }
  .card-name { font-size: 15px; font-weight: 700; color: var(--navy); line-height: 1.2; }
  .buyer-card.winner .card-name { color: var(--green); }
  .card-badge { font-size: 10px; color: var(--text-muted); margin-top: 2px; }
  .card-stars { font-size: 13px; color: var(--gold); flex-shrink: 0; }
  .card-body { padding: 14px 18px; }
  .card-desc { font-size: 12.5px; color: #444; line-height: 1.65; margin-bottom: 12px; }
  .card-table { width: 100%; font-size: 12px; border-collapse: collapse; }
  .card-table tr td { padding: 5px 8px; border-bottom: 1px solid var(--border); }
  .card-table tr:last-child td { border-bottom: none; }
  .card-table td:first-child { color: var(--text-muted); width: 40%; font-size: 11px; }
  .card-table td:last-child { font-weight: 500; }
  .winner-badge { display: inline-block; background: var(--green); color: white; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 12px; margin-left: 6px; }
  .card-footer { padding: 10px 18px; background: var(--grey); display: flex; gap: 8px; flex-wrap: wrap; }
  .tag { font-size: 10px; background: var(--blue-light); color: var(--blue); padding: 3px 8px; border-radius: 10px; font-weight: 600; }
  .tag.green { background: var(--green-light); color: var(--green); }
  .tag.amber { background: var(--amber-light); color: var(--amber); }
  .tag.gold { background: var(--gold-light); color: #7a5c10; }
  .priority-badge { margin-left: auto; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 10px; }
  .pA { background: var(--navy); color: white; }
  .pB { background: var(--blue); color: white; }
  .pC { background: #6c8db0; color: white; }

  /* ── TABLE ── */
  .data-table { width: 100%; border-collapse: collapse; background: white; border-radius: 10px; overflow: hidden; font-size: 12.5px; box-shadow: 0 1px 4px rgba(0,0,0,.06); }
  .data-table thead tr { background: var(--navy); color: white; }
  .data-table thead th { padding: 11px 14px; text-align: left; font-size: 11px; font-weight: 600; }
  .data-table tbody tr { border-bottom: 1px solid var(--border); }
  .data-table tbody tr:last-child { border-bottom: none; }
  .data-table tbody tr:nth-child(even) { background: var(--grey); }
  .data-table tbody td { padding: 10px 14px; vertical-align: top; }
  .data-table tbody tr.winner-row { background: var(--green-light); font-weight: 600; }
  .fit-H { background: #D5EDD5; color: var(--green); padding: 2px 8px; border-radius: 8px; font-size: 11px; font-weight: 700; }
  .fit-M { background: var(--amber-light); color: var(--amber); padding: 2px 8px; border-radius: 8px; font-size: 11px; font-weight: 700; }
  .fit-L { background: var(--red-light); color: #a72828; padding: 2px 8px; border-radius: 8px; font-size: 11px; font-weight: 700; }
  .fit-VH { background: #9AE6B4; color: #1A4731; padding: 2px 8px; border-radius: 8px; font-size: 11px; font-weight: 700; }

  /* ── OUTREACH ── */
  .outreach-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  @media (max-width: 700px) { .outreach-grid { grid-template-columns: 1fr; } }
  .phase-box { background: white; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
  .phase-head { padding: 16px 20px; color: white; }
  .phase-head.p1 { background: var(--navy); }
  .phase-head.p2 { background: var(--blue); }
  .phase-title { font-size: 14px; font-weight: 700; margin-bottom: 2px; }
  .phase-meta { font-size: 11px; opacity: .7; }
  .phase-list { padding: 14px 20px; display: flex; flex-direction: column; gap: 10px; }
  .phase-item { display: flex; align-items: flex-start; gap: 10px; }
  .phase-num { width: 22px; height: 22px; background: var(--navy); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; flex-shrink: 0; margin-top: 1px; }
  .phase-box:last-child .phase-num { background: var(--blue); }
  .phase-item-name { font-weight: 700; font-size: 12.5px; color: var(--navy); }
  .phase-item-desc { font-size: 11.5px; color: var(--text-muted); line-height: 1.4; }

  /* ── DEAL STRUCTURE ── */
  .structure-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; }
  .struct-card { background: white; border: 1px solid var(--border); border-radius: 10px; padding: 18px; }
  .struct-icon { font-size: 22px; margin-bottom: 10px; }
  .struct-name { font-size: 13px; font-weight: 700; color: var(--navy); margin-bottom: 6px; }
  .struct-desc { font-size: 11.5px; color: var(--text-muted); line-height: 1.5; margin-bottom: 10px; }
  .struct-buyers { font-size: 11px; font-weight: 600; color: var(--blue); }
  .struct-note { font-size: 10.5px; color: var(--amber); margin-top: 4px; }

  /* ── CONTEXT CARDS ── */
  .context-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; }
  .ctx-card { background: white; border: 1px solid var(--border); border-radius: 10px; padding: 16px; }
  .ctx-label { font-size: 11px; font-weight: 700; color: var(--text-muted); margin-bottom: 4px; text-transform: uppercase; letter-spacing: .5px; }
  .ctx-val { font-size: 13px; font-weight: 600; color: var(--navy); line-height: 1.4; }

  /* ── POS/NEG ── */
  .pn-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
  @media (max-width: 600px) { .pn-grid { grid-template-columns: 1fr; } }
  .pos-box, .neg-box { background: white; border-radius: 10px; padding: 18px; }
  .pos-box { border-left: 4px solid var(--green); }
  .neg-box { border-left: 4px solid #dc3545; }
  .pn-title { font-size: 12px; font-weight: 700; margin-bottom: 10px; }
  .pos-box .pn-title { color: var(--green); }
  .neg-box .pn-title { color: #dc3545; }
  .pn-list { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .pn-list li { font-size: 12.5px; padding-left: 14px; position: relative; color: #444; }
  .pn-list li::before { content: '•'; position: absolute; left: 0; }
  .pos-box .pn-list li::before { color: var(--green); }
  .neg-box .pn-list li::before { color: #dc3545; }

  /* ── DISCLAIMER ── */
  .disclaimer { background: var(--grey); border: 1px solid var(--border); border-radius: 8px; padding: 14px 18px; font-size: 11px; color: var(--text-muted); margin-top: 48px; line-height: 1.6; }
  .disclaimer b { color: var(--text); }

  /* ── FOOTER ── */
  .footer { background: var(--dark-navy); color: rgba(255,255,255,.4); text-align: center; padding: 24px; font-size: 11px; line-height: 1.8; }
  .footer b { color: rgba(255,255,255,.65); }

  /* ── RESPONSIVE ── */
  @media (max-width: 600px) {
    .hero { padding: 36px 20px 28px; }
    .hero h1 { font-size: 24px; }
    .stats { flex-direction: column; }
    .stat { border-right: none; border-bottom: 1px solid rgba(255,255,255,.12); }
    .buyer-grid { grid-template-columns: 1fr; }
    .container { padding: 24px 16px; }
    .nav { padding: 0 12px; }
  }
</style>
</head>
